{
  "name": "vistrates",
  "version": "0.1.0",
  "private": true,
  "description": "Vistrates: a literate, reactive component platform for visual analytics — modern TypeScript rebuild.",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -k -n web,server -c blue,magenta \"pnpm --filter @vistrates/web dev\" \"pnpm --filter @vistrates/server dev\"",
    "dev:web": "pnpm --filter @vistrates/web dev",
    "dev:server": "pnpm --filter @vistrates/server dev",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
